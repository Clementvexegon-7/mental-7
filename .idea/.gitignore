# ================================================================
#  .gitignore — MindWell / mentalhealthcare_ke
# ================================================================

# ── IDE ───────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────
env/
venv/
.env/
head/
.venv/
ENV/

# ── Django ────────────────────────────────────────────────────
db.sqlite3
db.sqlite3-journal
*.sqlite3
staticfiles/
media/
local_settings.py

# ── Django migrations (keep these — they are part of the app)
# DO NOT add: mentalapp/migrations/

# ── Environment variables ─────────────────────────────────────
.env
.env.*
!.env.example

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Windows ───────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Testing / Coverage ────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.tox/

# ── Render / Railway deployment ───────────────────────────────
# (keep build.sh, Procfile, requirements.txt — those are needed)